{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/refs/heads/master/setting/schema.json",
  "diagnostics.globals": [
    "vim"
  ],
  "runtime": {
    "pathStrict": false,
    "version": "LuaJIT"
  },
  "telemetry.enable": true,
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "$XDG_DATA_HOME/nvim/site/pack/core/",
      "$XDG_PKG_HOME/.nvim/squashfs-root/usr"
    ]
  }
}
