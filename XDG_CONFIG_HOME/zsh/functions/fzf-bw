# shellcheck shell=bash
# shellcheck disable=SC2168
# vi: ft=sh

local unlocked
unlocked="$(curl -sf "$BW_API/status" | jq -r '.data.template.status')"

if [[ $unlocked != "unlocked" ]]; then
	echo >&2 "Vault is locked"
	return 1
fi

curl -sf "$BW_API/list/object/items" |
	jq -r \
		'
	.data.data[] |
	[	.folderId // "/",
		.name, .login.uris[0].uri // "",
		.login.username // "",
		.id
	] |
	@tsv
	' |
	fzf --sync --with-nth 1..-2 --delimiter '\t' |
	awk '{print $NF}'
